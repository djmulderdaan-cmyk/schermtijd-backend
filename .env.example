PORT=3000
JWT_SECRET=verander-dit-in-een-lange-willekeurige-string

# Connectiestring van je Retool Database (of elke andere Postgres-server).
# In Retool: open je database-resource -> tabblad "Connect using" -> kopieer de Postgres-URI.
# Voorbeeld: postgresql://gebruiker:wachtwoord@abc123.retooldb.com:5432/retool?sslmode=require
DATABASE_URL=postgresql://gebruiker:wachtwoord@host:5432/database?sslmode=require
